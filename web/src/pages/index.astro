---
import Layout from '../layouts/Layout.astro';
import ProjectList from '../components/ProjectList.svelte';
import projectsData from '../data/projects.json';
import { initializeApp, getApps } from 'firebase/app';
import { getFirestore, collection, getDocs, orderBy, query } from 'firebase/firestore';

// Initialize Firebase for build-time fetching
let firebaseConfig: any = {};
try {
    firebaseConfig = JSON.parse(import.meta.env.PUBLIC_FIREBASE_CONFIG || '{}');
} catch (e) {
    // Silence error to fallback gracefully
}
let projects = [];

if (firebaseConfig.apiKey) {
    if (getApps().length === 0) {
        initializeApp(firebaseConfig);
    }
    const db = getFirestore();
    const q = query(collection(db, "projects"), orderBy("stars", "desc"));
    const querySnapshot = await getDocs(q);
    projects = querySnapshot.docs.map((doc: any) => doc.data());
} 

// Fallback to local JSON if Firestore fetch fails or not configured
if (projects.length === 0) {
    projects = projectsData || [];
}
---

<Layout title="Alvin Huang | GitHub Portfolio">
	<!-- Hero Section -->
	<div class="relative pt-12 pb-20 sm:pt-20 sm:pb-28">
		<div class="flex flex-col items-center text-center">
			
			<div class="mb-8 inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-sm font-medium">
				<span class="relative flex h-2 w-2">
				  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
				  <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
				</span>
				Available for new opportunities
			</div>
			
			<div class="mb-8">
				<img src="/profile.png" alt="Alvin Huang" class="w-32 h-32 md:w-40 md:h-40 rounded-full object-cover shadow-[0_0_40px_rgba(99,102,241,0.4)] border-4 border-white/10 mx-auto transition-transform hover:scale-105 duration-300" />
			</div>
			
			<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
				Hi, I'm <span class="text-transparent bg-clip-text bg-linear-to-r from-indigo-400 via-purple-400 to-pink-400">Alvin Huang</span>
			</h1>
			
			<p class="mt-4 max-w-2xl text-lg md:text-xl text-gray-400 mb-10 leading-relaxed">
				I build digital experiences with modern web technologies. Welcome to my portfolio, featuring over <span class="text-white font-medium">{projects.length}</span> open-source projects synchronized directly from GitHub.
			</p>
			
			<div class="flex flex-col sm:flex-row gap-4">
				<a href="#projects" class="px-8 py-3 rounded-full bg-white text-black font-semibold hover:bg-gray-100 transition-colors shadow-[0_0_20px_rgba(255,255,255,0.3)] hover:shadow-[0_0_25px_rgba(255,255,255,0.5)]">
					View Projects
				</a>
				<a href="https://github.com/alvin999" target="_blank" rel="noopener noreferrer" class="px-8 py-3 rounded-full bg-white/5 border border-white/10 text-white font-medium hover:bg-white/10 transition-colors flex items-center justify-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none">
						<path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.298 24 12c0-6.627-5.373-12-12-12"/>
					</svg>
					GitHub Profile
				</a>
			</div>
			
		</div>
	</div>

	<!-- Projects Section -->
	<section id="projects" class="pt-10 scroll-mt-20">
		<div class="mb-10 flex items-center justify-between">
			<div>
				<h2 class="text-3xl font-bold text-white mb-2">Featured Projects</h2>
				<p class="text-gray-400">Filter and search through the open source repositories.</p>
			</div>
		</div>
		
		<!-- Svelte Island Component -->
		<ProjectList client:load initialProjects={projects} />
	</section>
</Layout>
