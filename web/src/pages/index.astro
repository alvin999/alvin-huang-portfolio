---
import Layout from "../layouts/Layout.astro";
import ProjectList from "../components/ProjectList.svelte";
import CoffeeToCode from "../components/CoffeeToCode.svelte";
import RemotionFeaturedProjectsWrapper from "../components/RemotionFeaturedProjectsWrapper.svelte";
import { RemotionHeroPlayer } from "../remotion/RemotionHeroPlayer";
import projectsData from "../data/projects.json";
import { initializeApp, getApps } from "firebase/app";
import {
	getFirestore,
	collection,
	getDocs,
	orderBy,
	query,
} from "firebase/firestore";

// Initialize Firebase for build-time fetching
let firebaseConfig: any = {};
try {
	firebaseConfig = JSON.parse(import.meta.env.PUBLIC_FIREBASE_CONFIG || "{}");
} catch (e) {}
let projects = [];

if (firebaseConfig.apiKey) {
	if (getApps().length === 0) {
		initializeApp(firebaseConfig);
	}
	const db = getFirestore();
	const q = query(collection(db, "projects"), orderBy("stars", "desc"));
	const querySnapshot = await getDocs(q);
	projects = querySnapshot.docs.map((doc: any) => ({
		id: doc.id,
		...doc.data(),
	})).filter((p: any) => p.is_featured);
}

// Fallback to local JSON
if (projects.length === 0) {
	projects = (projectsData || []).filter((p: any) => p.is_featured);
}
---

<Layout title="Alvin Huang | GitHub Portfolio">
	<!-- Hero Section: GSAP 主題 -->
	<div
		id="hero-trigger"
		class="relative h-[350vh] z-40"
		data-count={projects.length}
	>
		<div
			id="sticky-hero"
			class="sticky top-0 h-screen flex flex-col items-center justify-start pt-[10vh] z-40 scale-[0.8] origin-top"
		>
			<!-- 背景裝飾 -->
			<div class="absolute inset-0 -z-10 opacity-30">
				<div
					class="absolute top-1/4 left-1/4 w-96 h-96 bg-gb-aqua/20 blur-[120px] rounded-full"
				>
				</div>
				<div
					class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-gb-green/20 blur-[120px] rounded-full"
				>
				</div>
			</div>

			<!-- 核心主角：個人照片 (縮小 20% 以達到平衡) -->
			<div
				id="avatar-container"
				class="relative z-10 scale-[1.2] md:scale-[1.4]"
			>
				<!-- 主頭照 -->
				<div class="relative group">
					<div
						class="absolute inset-0 bg-gb-orange/20 blur-[60px] rounded-full -z-10"
					>
					</div>
					<img
						src="/profile.png"
						alt="Alvin Huang"
						class="w-[55vw] h-[55vw] md:w-[55vh] md:h-[55vh] object-cover shadow-2xl transition-all"
						style="mask-image: radial-gradient(circle, black 30%, transparent 80%); -webkit-mask-image: radial-gradient(circle, black 30%, transparent 80%);"
					/>

					<!-- 徽章 (Badge): 位於照片右下角，純識別資訊 -->
					<div
						id="profile-badge"
						class="absolute bottom-[-2%] right-[-5%] md:bottom-[0%] md:right-[-12%] bg-gb-bg-soft/40 backdrop-blur-3xl border border-white/10 p-2 md:p-6 rounded-3xl md:rounded-[2.5rem] shadow-[0_20px_40px_rgba(0,0,0,0.5)] flex items-center gap-3 md:gap-6 transition-colors overflow-hidden scale-[0.75] md:scale-100 origin-bottom-right"
					>
						<div
							id="badge-shine"
							class="absolute inset-0 bg-linear-to-r from-transparent via-white/40 to-transparent -translate-x-[150%] pointer-events-none w-[200%] h-full rotate-12"
						>
						</div>
						<!-- 職業圖示 -->
						<div
							class="w-10 h-10 md:w-20 md:h-20 rounded-xl md:rounded-2xl bg-gb-orange/10 border border-gb-orange/30 flex items-center justify-center shrink-0"
						>
							<svg
								class="w-5 h-5 md:w-10 md:h-10 text-gb-orange"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"
								></path>
							</svg>
						</div>
						<div class="text-left pr-2 md:pr-4">
							<p
								class="text-[8px] md:text-xs text-gb-orange font-black tracking-widest uppercase mb-0.5 md:mb-1"
							>
								Developer
							</p>
							<h3
								class="text-sm md:text-2xl text-white font-black tracking-tight"
							>
								Alvin Huang
							</h3>
							<p
								class="hidden md:block text-xs md:text-sm text-gray-500 font-bold tracking-tighter"
							>
								@alvin999
							</p>
						</div>
					</div>
				</div>
			</div>

			<div id="hero-text" class="mt-[15vh] text-center max-w-4xl px-4">
				<h1
					id="hero-title"
					class="text-6xl md:text-8xl font-black tracking-tighter mb-6"
				>
					Hi, I'm <span
						class="text-transparent bg-clip-text bg-linear-to-r from-gb-orange via-gb-yellow to-gb-red"
						>Alvin Huang</span
					>
				</h1>
				<p
					id="hero-desc"
					class="text-xl md:text-2xl text-gray-400 leading-relaxed mb-10 opacity-70"
				>
					I build digital experiences with modern web technologies.<br
						class="hidden md:block"
					/>
					Exploring the future of web through
				</p>
				<div class="mb-12">
					<span
						id="project-count"
						class="text-7xl md:text-9xl font-black text-transparent bg-clip-text bg-linear-to-b from-white to-white/20 block"
						>0</span
					>
					<span
						class="text-sm md:text-base text-gb-orange font-bold tracking-[0.3em] uppercase"
						>Open Source Projects</span
					>
				</div>
				<div
					id="hero-cta"
					class="flex flex-col sm:flex-row gap-6 justify-center"
				>
					<a
						href="#projects"
						class="px-10 py-4 rounded-full bg-white text-black font-bold hover:scale-105 transition-transform shadow-[0_0_30px_rgba(255,255,255,0.2)]"
					>
						Explore Work
					</a>
				</div>
			</div>

			<!-- 已移除捲動指示以保持純淨 -->
		</div>
	</div>

	<!-- Content Section: z-index 必須低於 hero-trigger (z-40) -->
	<div id="content-section" class="relative z-10">
		<!-- Coffee to Code Animation Section -->
		<CoffeeToCode client:visible />

		<div class="pt-20 px-4 sm:px-8">
			<!-- Projects Section -->
		<section id="projects" class="max-w-7xl mx-auto py-20 scroll-mt-20">
			<!-- 標題區塊：由 Remotion 動畫驅動 -->
			<div
				id="projects-animation-container"
				class="w-full h-[500px] md:h-[650px] flex items-center justify-center overflow-hidden"
			>
				<RemotionFeaturedProjectsWrapper 
					client:visible 
					title="Featured Projects" 
					subtitle="A collection of technical experiments and tools." 
				/>
			</div>

			<!-- Svelte Island Component -->
			<div class="gsap-reveal-stagger">
				<ProjectList client:load initialProjects={projects} />
			</div>
		</section>

		<!-- Footer -->
		<footer class="py-20 border-t border-white/5 text-center text-gray-500">
			<p>© 2026 Alvin Huang. Built with Astro, Svelte, and Remotion.</p>
		</footer>
	</div>

	<!-- GSAP Scripts -->
	<script>
		import { gsap } from "gsap";
		import { ScrollTrigger } from "gsap/ScrollTrigger";

		gsap.registerPlugin(ScrollTrigger);

		// 1. Hero 整體縮放與位移 (頭像 + 標題)
		const heroTl = gsap.timeline({
			scrollTrigger: {
				trigger: "#hero-trigger",
				start: "top top",
				end: "bottom bottom",
				scrub: 1.5,
				onUpdate: (self) => {
					// 從 DOM 讀取專案總數，再依捲動進度計算當前顯示值
					const totalProjects = parseInt(
						document.getElementById("hero-trigger")?.dataset
							?.count ?? "0",
						10,
					);
					const current = Math.round(self.progress * totalProjects);
					const el = document.getElementById("project-count");
					if (el) el.textContent = String(current);
				},
			},
		});

		heroTl.to(
			"#avatar-container",
			{
				scale: 0.4,
				y: -250,
				opacity: 0,
			},
			0,
		);

		heroTl.to(
			"#hero-text",
			{
				y: -300,
			},
			0,
		);

		heroTl.to(
			"#profile-badge",
			{
				x: 60,
				scale: 0.9,
			},
			0,
		);

		// 2. 獨立的掃光動畫 (一捲動就出現)
		gsap.to("#badge-shine", {
			scrollTrigger: {
				trigger: "#hero-trigger",
				start: "top top",
				end: "15% top",
				scrub: 1,
			},
			x: "150%",
			ease: "none",
		});

		// 3. 標題與 CTA 進場
		gsap.from("#hero-title", {
			opacity: 0,
			y: 30,
			duration: 1.2,
			delay: 0.2,
			ease: "expo.out",
		});
		gsap.from("#hero-desc", {
			opacity: 0,
			y: 20,
			duration: 1.2,
			delay: 0.4,
			ease: "expo.out",
		});
		gsap.from("#hero-cta", {
			opacity: 0,
			scale: 0.9,
			duration: 1.2,
			delay: 0.6,
			ease: "expo.out",
		});

		// 4. 內容區塊揭露動畫
		gsap.utils.toArray(".gsap-reveal").forEach((elem: any) => {
			gsap.from(elem, {
				scrollTrigger: {
					trigger: elem,
					start: "top 85%",
					toggleActions: "play none none reverse",
				},
				y: 50,
				opacity: 0,
				duration: 1,
				ease: "power3.out",
			});
		});

		// 5. 專案列表交錯揭露
		gsap.from(".gsap-reveal-stagger", {
			scrollTrigger: {
				trigger: ".gsap-reveal-stagger",
				start: "top 80%",
				toggleActions: "play none none reverse",
			},
			y: 100,
			opacity: 0,
			duration: 1.5,
			ease: "power4.out",
		});

		// 6. Featured Projects Remotion 同步動畫
		gsap.to("#projects-animation-container", {
			scrollTrigger: {
				trigger: "#projects-animation-container",
				start: "top 90%",
				end: "bottom 20%",
				scrub: true,
				onUpdate: (self) => {
					window.dispatchEvent(new CustomEvent('projects-scroll', { 
						detail: { progress: self.progress } 
					}));
				}
			}
		});
	</script>
</Layout>
