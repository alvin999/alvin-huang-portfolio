rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for builds
    match /projects/{project} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "bingoppp@gmail.com";
    }
    
    match /partners/{partner} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "bingoppp@gmail.com";
    }

    match /settings/{setting} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "bingoppp@gmail.com";
    }
  }
}
